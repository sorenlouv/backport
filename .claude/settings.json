{
  "permissions": {
    "allow": [
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(gh *)",
      "Bash(node *)",
      "Bash(git add:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git diff*)",
      "Bash(git ls-tree:*)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(sort *)",
      "Bash(top *)",
      "Bash(ps *)"
    ]
  },
  "defaultMode": "bypassPermissions",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/setup-worktree.sh"
          }
        ]
      }
    ]
  }
}
